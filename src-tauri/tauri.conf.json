{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Foundry Slag",
  "version": "1.0.0",
  "identifier": "com.hansonfoundry.slag",
  "build": {
    "beforeDevCommand": "cd foundry-slag-frontend && npm run dev",
    "beforeBuildCommand": "cd foundry-slag-frontend && npm run build",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../foundry-slag-frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Foundry Slag",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "GraphicsAndDesign",
    "copyright": "© Hanson Foundry",
    "shortDescription": "Slag the background. Keep the gold. All on your Mac.",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "entitlements.plist",
      "files": {
        "Info.plist": "Info.plist"
      },
      "exceptionDomain": "localhost"
    }
  }
}
